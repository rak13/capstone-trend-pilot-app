      "link": null,
      "locked": false,
      "text": "systemd  —  trendpilot-backend.service\n────────────────────────────────────────\nUser: ec2-user\nWorkingDirectory: ./backend\nExecStart: uvicorn main:app\n           --host 127.0.0.1 --port 8000\nEnvironmentFile: backend/.env\nRestart=on-failure   RestartSec=5\nWantedBy=multi-user.target\nAuto-starts on reboot (systemctl enable)",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "systemd  —  trendpilot-backend.service\n────────────────────────────────────────\nUser: ec2-user\nWorkingDirectory: ./backend\nExecStart: uvicorn main:app\n           --host 127.0.0.1 --port 8000\nEnvironmentFile: backend/.env\nRestart=on-failure   RestartSec=5\nWantedBy=multi-user.target\nAuto-starts on reboot (systemctl enable)",
