    },
    {
      "type": "text",
      "id": "text_update",
      "x": 658.2426233685426,
      "y": 818.17814023802,
      "width": 325,
      "height": 294,
      "angle": 0,
      "strokeColor": "#1e3a8a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "roundness": null,
      "boundElements": [],
      "updated": 1772874926179,
      "link": null,
      "locked": false,
      "text": "Re-deploy  —  setup.sh --skip-cert\n──────────────────────────────────\nOn EC2:\n  ssh ec2-user@<EC2-IP>\n  cd capstone-trend-pilot-app\n  git pull\n\n  export OPENAI_API_KEY=sk-...\n  export DASHSCOPE_API_KEY=sk-...\n  export LINKEDIN_CLIENT_SECRET=...\n\n  ./setup.sh --skip-cert\n\nFlags:\n  --skip-cert    skip SSL (cert exists)\n  --skip-build   skip npm build\n\nScript auto-runs:\n  -> reinstalls Python deps\n  -> rebuilds React frontend\n  -> reloads Nginx (zero downtime)\n  -> restarts systemd service",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Re-deploy  —  setup.sh --skip-cert\n──────────────────────────────────\nOn EC2:\n  ssh ec2-user@<EC2-IP>\n  cd capstone-trend-pilot-app\n  git pull\n\n  export OPENAI_API_KEY=sk-...\n  export DASHSCOPE_API_KEY=sk-...\n  export LINKEDIN_CLIENT_SECRET=...\n\n  ./setup.sh --skip-cert\n\nFlags:\n  --skip-cert    skip SSL (cert exists)\n  --skip-build   skip npm build\n\nScript auto-runs:\n  -> reinstalls Python deps\n  -> rebuilds React frontend\n  -> reloads Nginx (zero downtime)\n  -> restarts systemd service",
      "version": 47,
      "versionNonce": 1353392421,
      "index": "d4",
      "isDeleted": false,
      "seed": 35,
      "frameId": null,
      "autoResize": false,
      "lineHeight": 1.4
    },
