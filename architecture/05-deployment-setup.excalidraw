      "boundElements": [],
      "updated": 1750000000000,
      "link": null,
      "locked": false,
      "text": "Nginx  —  Reverse Proxy + SSL Termination\n─────────────────────────────────────────\n:80  ->  301 redirect to :443\n:443 ->  SSL termination (TLS 1.2/1.3)\n\n/*     -> serve frontend/dist/ (static)\n         try_files $uri $uri/ /index.html\n/api/* -> proxy_pass 127.0.0.1:8000\n         proxy_read_timeout 120s\n\nSSL:  /etc/letsencrypt/live/ineedq.com/\nConf: /etc/nginx/conf.d/ineedq.com.conf",
      "fontSize": 13,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Nginx  —  Reverse Proxy + SSL Termination\n─────────────────────────────────────────\n:80  ->  301 redirect to :443\n:443 ->  SSL termination (TLS 1.2/1.3)\n\n/*     -> serve frontend/dist/ (static)\n         try_files $uri $uri/ /index.html\n/api/* -> proxy_pass 127.0.0.1:8000\n         proxy_read_timeout 120s\n\nSSL:  /etc/letsencrypt/live/ineedq.com/\nConf: /etc/nginx/conf.d/ineedq.com.conf",
      "version": 1,
      "versionNonce": 7,
      "index": "a6",
      "isDeleted": false,
