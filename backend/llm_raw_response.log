  "type": "diagram",
  "diagram_code": "<<<DIAGRAM_CODE_START>>>\ndigraph MicroservicesPatterns {\n    rankdir=LR;\n\n    // Node styles\n    node [fontname=\"Helvetica\", fontsize=11];\n\n    // Monolith cluster\n    subgraph cluster_monolith {\n        label=\"Monolith (When to Keep It)\";\n        style=filled;\n        fillcolor=lightgreen;\n        Monolith [label=\"Monolith\\n• One repo\\n• One RDS\\n• Feature flags\\n• Python workers\" shape=box style=filled fillcolor=lightgreen];\n    }\n\n    // Outbox pattern cluster\n    subgraph cluster_outbox {\n        label=\"Outbox Pattern\";\n        style=filled;\n        fillcolor=lightyellow;\n        ServiceA [label=\"Service A\\n(Writer)\" shape=box style=filled fillcolor=gold];\n        OutboxTable [label=\"Outbox Table\\n(RDS)\" shape=cylinder style=filled fillcolor=khaki];\n        Lambda [label=\"Lambda\\n(Drainer)\" shape=box style=filled fillcolor=orange];\n        EventBridge [label=\"EventBridge\" shape=box style=filled fillcolor=lightsalmon];\n        \n        ServiceA -> OutboxTable [label=\"INSERT\" fontcolor=darkgreen];\n        OutboxTable -> Lambda [label=\"Polling\" fontcolor=darkgreen];\n        Lambda -> EventBridge [label=\"Publish\\n(idempotent)\" fontcolor=darkgreen];\n    }\n\n    // Saga pattern cluster\n    subgraph cluster_saga {\n        label=\"Saga Pattern\";\n        style=filled;\n        fillcolor=lightcyan;\n        Orchestrator [label=\"Step Functions\\n(Orchestrator)\" shape=box style=filled fillcolor=skyblue];\n        PaymentSvc [label=\"Payments\" shape=box style=filled fillcolor=paleturquoise];\n        InventorySvc [label=\"Inventory\" shape=box style=filled fillcolor=paleturquoise];\n        ShippingSvc [label=\"Shipping\" shape=box style=filled fillcolor=paleturquoise];\n        Compensation [label=\"Compensating\\nActions\" shape=diamond style=filled fillcolor=lightcoral];\n        \n        Orchestrator -> PaymentSvc [label=\"Start\" fontcolor=navy];\n        PaymentSvc -> Orchestrator [label=\"Success/Failed\" fontcolor=navy];\n        Orchestrator -> InventorySvc [label=\"Next\" fontcolor=navy];\n        InventorySvc -> Orchestrator [label=\"Success/Failed\" fontcolor=navy];\n        Orchestrator -> ShippingSvc [label=\"Next\" fontcolor=navy];\n        ShippingSvc -> Orchestrator [label=\"Success/Failed\" fontcolor=navy];\n        Orchestrator -> Compensation [label=\"On failure\" fontcolor=red];\n        Compensation -> Orchestrator [label=\"Rollback\" fontcolor=red];\n    }\n\n    // CQRS cluster\n    subgraph cluster_cqrs {\n        label=\"CQRS Pattern\";\n        style=filled;\n        fillcolor=plum;\n        WriteModel [label=\"Write Model\\n(Node.js service)\\n• Lean writes\\n• Events published\" shape=box style=filled fillcolor=thistle];\n        EventStream [label=\"Event Stream\" shape=ellipse style=filled fillcolor=violet];\n        Projector [label=\"Python Projector\" shape=box style=filled fillcolor=orchid];\n        ReadModel [label=\"Read Models\\n• OpenSearch\\n• ElastiCache\" shape=box style=filled fillcolor=mediumpurple];\n        \n        WriteModel -> EventStream [label=\"publish\" fontcolor=white];\n        EventStream -> Projector [label=\"consume\" fontcolor=white];\n        Projector -> ReadModel [label=\"project\" fontcolor=white];\n    }\n\n    // Pain-driven decision flow\n    Decision [label=\"Domain pain?\\n• TPS >100?\\n• Team >6?\\n• Stable domain?\\n• Read/write skew?\" shape=diamond style=filled fillcolor=lightgray];\n    Decision -> Monolith [label=\"No — keep monolith\" fontcolor=darkgreen];\n    Decision -> Outbox [label=\"Yes — async pub/sub needed\" fontcolor=orange];\n    Decision -> Saga [label=\"Yes — cross-service ACID-like\" fontcolor=blue];\n    Decision -> CQRS [label=\"Yes — read-heavy, query complexity\" fontcolor=purple];\n}\n<<<DIAGRAM_CODE_END>>>"
}
