oject;\n    CLI -> Project;\n    Project -> Router;\n    Project -> ImageRegistry;\n    Project -> BuildSystem;\n    Project -> Pipeline;\n    Pipeline -> Git;\n    Pipeline -> ImageRegistry;\n    Project -> APIserver;\n    APIserver -> Scheduler;\n    APIserver -> ControllerManager;\n    Scheduler -> Kubelet;\n    ControllerManager -> Kubelet;\n    Kubelet -> Nodes;\n    Nodes -> Storage;\n    Nodes -> Network;\n}\n<<<DIAGRAM_CODE_END>>>"
