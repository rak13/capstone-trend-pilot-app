  "diagram_code": "<<<DIAGRAM_CODE_START>>>\ndigraph SagaComparison {\n    rankdir=LR;\n\n    // Kafka Choreography Cluster\n    subgraph cluster_kafka_choreo {\n        label=\"Kafka-First Choreography\";\n        style=filled;\n        fillcolor=lightcoral;\n        node [shape=box, style=filled, fillcolor=white];\n        Kafka [label=\"Kafka\\n(Cluster)\" shape=cylinder fillcolor=lightcoral];\n        ServiceA [label=\"Service A\\n(Node.js)\"]; \n        ServiceB [label=\"Service B\\n(Java)\"];\n        ServiceC [label=\"Service C\\n(Python)\"];\n        Kafka -> ServiceA [label=\"event\"];\n        Kafka -> ServiceB [label=\"event\"];\n        Kafka -> ServiceC [label=\"event\"];\n        ServiceA -> Kafka [label=\"outbox event\"];\n        ServiceB -> Kafka [label=\"outbox event\"];\n        ServiceC -> Kafka [label=\"outbox event\"];\n    }\n\n    // Temporal Orchestration Cluster\n    subgraph cluster_temporal_orch {\n        label=\"Temporal Orchestrator\";\n        style=filled;\n        fillcolor=lightgreen;\n        node [shape=box, style=filled, fillcolor=white];\n        Temporal [label=\"Temporal\\n(Workflow Service)\" shape=box fillcolor=lightgreen];\n        Workflow [label=\"Order-to-Cash\\nWorkflow\" shape=diamond fillcolor=lightgreen];\n        Temporal -> Workflow;\n        Workflow -> ServiceA [label=\"invoke\"];\n        Workflow -> ServiceB [label=\"invoke\"];\n        Workflow -> ServiceC [label=\"invoke\"];\n        ServiceA -> Workflow [label=\"result/compensate\"];\n        ServiceB -> Workflow [label=\"result/compensate\"];\n        ServiceC -> Workflow [label=\"result/compensate\"];\n    }\n\n    // Shared Outbox & Analytics (Kafka still used)\n    subgraph cluster_kafka_outbox {\n        label=\"Kafka (Outbox & Analytics)\";\n        style=filled;\n        fillcolor=lightskyblue;\n        Outbox [label=\"Outbox Table\" shape=cylinder fillcolor=lightskyblue];\n        Analytics [label=\"Analytics\\nConsumers\" shape=box fillcolor=lightskyblue];\n        ServiceA -> Outbox [label=\"write\"];\n        ServiceB -> Outbox [label=\"write\"];\n        ServiceC -> Outbox [label=\"write\"];\n        Outbox -> Analytics [label=\"stream\"];\n    }\n\n    // Legend nodes (bottom right)\n    legend_kafka [label=\"Kafka: Event Bus & Streaming\" shape=note style=filled fillcolor=lightcoral fontcolor=black];\n    legend_temporal [label=\"Temporal: Stateful Orchestration\" shape=note style=filled fillcolor=lightgreen fontcolor=black];\n    legend_outbox [label=\"Outbox Pattern: Reliable Event Publishing\" shape=note style=filled fillcolor=lightskyblue fontcolor=black];\n\n    // Layout hints\n    {rank=same; Kafka; Temporal; Outbox}\n    {rank=same; legend_kafka; legend_temporal; legend_outbox}\n}\n<<<DIAGRAM_CODE_END>>>"
}
