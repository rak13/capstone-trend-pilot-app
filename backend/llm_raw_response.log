{
  "type": "diagram",
  "diagram_code": "<<<DIAGRAM_CODE_START>>>\ndigraph MicroservicesPatterns {\n    rankdir=LR;\n\n    // Node styles\n    node [fontname=\"Helvetica\", fontsize=10];\n\n    // Outbox Pattern\n    subgraph cluster_outbox {\n        label=\"Outbox Pattern\";\n        style=filled;\n        fillcolor=lightcyan;\n        OutboxService [label=\"Service\\n(Write)\" shape=box style=filled fillcolor=lightgreen];\n        OutboxTable [label=\"Outbox Table\\n(RDS)\" shape=cylinder style=filled fillcolor=lightgray];\n        LambdaDrainer [label=\"Lambda\\n(Outbox Drainer)\" shape=box style=filled fillcolor=gold];\n        EventBridge [label=\"EventBridge\" shape=box style=filled fillcolor=orange];\n        \n        OutboxService -> OutboxTable [label=\"INSERT\" fontcolor=darkgreen];\n        LambdaDrainer -> OutboxTable [label=\"SELECT\\n(idempotent)\" fontcolor=darkblue];\n        LambdaDrainer -> EventBridge [label=\"Publish\\n(idempotency key)\" fontcolor=darkred];\n    }\n\n    // Saga Pattern\n    subgraph cluster_saga {\n        label=\"Saga Pattern\";\n        style=filled;\n        fillcolor=lightpink;\n        StepFunctions [label=\"Step Functions\\n(Orchestrator)\" shape=box style=filled fillcolor=purple];\n        Payments [label=\"Payments\\nService\" shape=box style=filled fillcolor=lightblue];\n        Inventory [label=\"Inventory\\nService\" shape=box style=filled fillcolor=lightblue];\n        Shipping [label=\"Shipping\\nService\" shape=box style=filled fillcolor=lightblue];\n        SQSCompensate [label=\"SQS\\n(Compensation)\" shape=cylinder style=filled fillcolor=lightyellow];\n        \n        StepFunctions -> Payments;\n        StepFunctions -> Inventory;\n        StepFunctions -> Shipping;\n        Payments -> SQSCompensate [label=\"on failure\" fontcolor=red];\n        Inventory -> SQSCompensate [label=\"on failure\" fontcolor=red];\n        Shipping -> SQSCompensate [label=\"on failure\" fontcolor=red];\n    }\n\n    // CQRS Pattern\n    subgraph cluster_cqrs {\n        label=\"CQRS Pattern\";\n        style=filled;\n        fillcolor=lightgoldenrodyellow;\n        WriteService [label=\"Node.js\\nWrite Service\" shape=box style=filled fillcolor=lightcoral];\n        EventStream [label=\"Event Stream\\n(Kinesis/SQS)\" shape=cylinder style=filled fillcolor=skyblue];\n        ProjectionLambda [label=\"Python\\nProjection Lambda\" shape=box style=filled fillcolor=gold];\n        OpenSearch [label=\"OpenSearch\\n(Read Model)\" shape=cylinder style=filled fillcolor=seagreen];\n        ElastiCache [label=\"ElastiCache\\n(Read Model)\" shape=cylinder style=filled fillcolor=seagreen];\n        \n        WriteService -> EventStream [label=\"publish event\"];\n        ProjectionLambda -> EventStream [label=\"consume\"];\n        ProjectionLambda -> OpenSearch [label=\"project\"];\n        ProjectionLambda -> ElastiCache [label=\"project\"];\n    }\n\n    // Monolith (contrast)\n    subgraph cluster_monolith {\n        label=\"Monolith\\n(When to prefer)\";\n        style=filled;\n        fillcolor=lightsteelblue;\n        MonolithApp [label=\"Single Repo\\n+ RDS\\n+ Python Workers\" shape=box style=filled fillcolor=white];\n        FeatureFlags [label=\"Feature Flags\" shape=diamond style=filled fillcolor=plum];\n        \n        MonolithApp -> FeatureFlags;\n    }\n\n    // Layout constraints\n    {rank=same; OutboxService; StepFunctions; WriteService; MonolithApp}\n    {rank=same; OutboxTable; Payments; EventStream; MonolithApp}\n}\n<<<DIAGRAM_CODE_END>>>"
}
