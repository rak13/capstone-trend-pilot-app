ge [label=\"Persistent Storage\" shape=cylinder style=filled fillcolor=white];\n        Network [label=\"SDN (OVN/Kuryr)\" shape=box style=filled fillcolor=white];\n    }\n\n    /* Edges */\n    Developer -> WebConsole [label=\"UI interaction\"];\n    Developer -> CLI [label=\"command-line\"];\n    CLI -> GitRepo [label=\"push trigger\"];\n    GitRepo -> BuildConfig [label=\"webhook\"];\n    BuildConfig -> ImageStream [label=\"build output\"];\n    ImageStream -> DeploymentConfig [label=\"image update\"];\n    DeploymentConfig -> Project [label=\"deploy to namespace\"];\n    Project -> Router [label=\"ingress routing\"];\n    Project -> Nodes [label=\"pod scheduling\"];\n\n    /* OpenShift abstracts and extends Kubernetes */\n    WebConsole -> APIserver [label=\"REST API\" color=blue fontcolor=blue];\n    CLI -> APIserver [label=\"REST API\" color=blue fontcolor=blue];\n    BuildConfig -> APIserver [label=\"CRD\" color=blue fontcolor=blue];\n    DeploymentConfig -> APIserver [label=\"CRD\" color=blue fontcolor=blue];\n    Router -> APIserver [label=\"ingress controller\"];\n\n    /* Kubernetes core components */\n    APIserver -> Scheduler;\n    APIserver -> ControllerManager;\n    APIserver -> Etcd;\n    Scheduler -> Kubelet;\n    ControllerManager -> Kubelet;\n    Kubelet -> Nodes;\n    Nodes -> Storage;\n    Nodes -> Network;\n}\n<<<DIAGRAM_CODE_END>>>"
